# Browser mode: 'cdp' | 'headless' | 'headed'
#   cdp      — connect to externally launched Chrome (requires --remote-debugging-port)
#   headless — Playwright launches Chrome in headless mode
#   headed     — Playwright launches visible Chrome window
E2E_BROWSER_MODE=headless

# Path to chrome.exe (used in headless/headed modes, and in cdp mode to auto-launch Chrome)
# Example: C:\Program Files\Google\Chrome\Application\chrome.exe
# When set in cdp mode, global-setup will auto-launch Chrome if not already running
CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# CDP connection (used only when E2E_BROWSER_MODE=cdp)
BROWSER_PORT=9222
REMOTE_CHROME_HOST=localhost

# Base URL of the application under test
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:3000/api
